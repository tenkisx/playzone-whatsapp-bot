# =====================================================================
# Play Zone — Assistente WhatsApp (Cloud API + IA + WooCommerce)
# Copia este ficheiro para ".env" e preenche com os teus valores.
# NUNCA partilhes este ficheiro nem o commites no git.
# Todos estes valores sao gerados/obtidos por TI (Victor). O bot le-os daqui.
# =====================================================================

# ---- Servidor ----
PORT=8080

# ---- WhatsApp Cloud API (Meta) ----
# Painel: https://developers.facebook.com/  ->  a tua App  ->  WhatsApp
# NUMERO DO CLIENTE (Cloud API, LIGADO): +244 923 170 471  |  WABA "Play Zone" 1501659204615287
# O +244 923 170 487 fica como WhatsApp Business manual + recebe os alertas (TEAM_ALERT_NUMBERS abaixo).
# O 959 722 488 esta PENDENTE (nao ligado) -> NAO usar.
# REUTILIZAR o token JA aplicado no ERP: o bot aceita tambem os nomes WHATSAPP_META_TOKEN
# e WHATSAPP_META_PHONE_ID. Se correres o bot com o .env do ERP, o token e reutilizado
# automaticamente (nao precisas de o voltar a colar). Basta garantir o phone_id de PRODUCAO.
WHATSAPP_TOKEN=            # (ou reutiliza WHATSAPP_META_TOKEN do ERP) Token permanente da Meta
WHATSAPP_PHONE_NUMBER_ID=            # <-- COLA AQUI o Phone number ID do 923 170 471
# (Meta: developers.facebook.com -> a tua App -> WhatsApp -> API Setup -> "Phone number ID").
# NAO uses 1174583372405366 (esse e do 959 722 488, que esta pendente).
WHATSAPP_VERIFY_TOKEN=     # String inventada por ti; poe a MESMA no webhook da Meta
WHATSAPP_APP_SECRET=       # App Secret da tua App Meta (para validar assinatura)
GRAPH_API_VERSION=v21.0
# ATENCAO governanca: este numero e PARTILHADO (Notiqoo/Hamburgaria + ERP enviam por ele).
# O webhook de ENTRADA (mensagens dos clientes) so pode apontar para UM destino.
# Coordenar com o Notiqoo/ERP antes do go-live (ver docs/WHATSAPP_GOVERNANCA.md).

# ---- IA (Anthropic Claude) ----
# Painel: https://console.anthropic.com/  ->  API Keys
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-5
AI_MAX_TOKENS=1024

# ---- WooCommerce (playzone.ao) ----
# WooCommerce -> Definicoes -> Avancado -> REST API -> Adicionar chave (Leitura/Escrita)
WOO_BASE_URL=https://playzone.ao
WOO_CONSUMER_KEY=
WOO_CONSUMER_SECRET=

# ---- Operacao ----
# Numero(s) da equipa que recebe alertas de encomenda (formato internacional, sem +)
TEAM_ALERT_NUMBERS=244923170487
# Horario de atendimento humano (informativo para o bot)
BUSINESS_HOURS=Seg-Sab 09:00-18:00
# Estado inicial das encomendas criadas no WooCommerce (on-hold = aguarda pagamento)
ORDER_STATUS=on-hold
